<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {%- set siteUrl = "https://writer.brennan.day" %}
  {%- set siteName = "writer-cli" %}
  {%- set siteDescription = "writer-cli, a terminal-based blog publishing tool" %}
  {%- set pageTitle = title + " | writer" if title != "writer" else "writer-cli: Write from your terminal. Publish with one command." %}
  {%- set pageDescription = description or siteDescription %}
  {%- set pageUrl = siteUrl + page.url %}
  {%- set imageUrl = siteUrl + "/img/screenshot.jpg" %}

  <!-- Primary -->
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">
  <meta name="author" content="Brennan Kenneth Brown">
  <meta name="generator" content="Eleventy">
  <link rel="canonical" href="{{ pageUrl }}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ siteName }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ pageUrl }}">
  <meta property="og:image" content="{{ imageUrl }}">
  <meta property="og:image:alt" content="writer-cli: a terminal-based blog publishing tool">
  <meta property="og:image:width" content="1024">
  <meta property="og:image:height" content="400">
  <meta property="og:locale" content="en_CA">

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ imageUrl }}">
  <meta name="twitter:image:alt" content="writer-cli: a terminal-based blog publishing tool">
  <meta name="twitter:creator" content="@brennankbrown">

  <!-- Structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "writer-cli",
    "description": "{{ pageDescription }}",
    "url": "{{ siteUrl }}",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Linux, macOS",
    "license": "https://www.gnu.org/licenses/agpl-3.0.html",
    "author": {
      "@type": "Person",
      "name": "Brennan Kenneth Brown",
      "url": "https://brennan.day"
    },
    "codeRepository": "https://github.com/brennanbrown/writer-cli",
    "image": "{{ imageUrl }}"
  }
  </script>

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/img/favicon.ico">
  <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#ffffff">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/prism-theme.css">
</head>
<body>
  <header class="site-header">
    <nav class="nav">
      <a href="/" class="nav-logo">
        <img src="/img/favicon-32x32.png" alt="writer-cli logo" width="20" height="20">
        writer
      </a>
      <ul class="nav-links">
        <li><a href="/" {% if page.url == "/" %}class="active"{% endif %}>home</a></li>
        <li><a href="/guide/" {% if page.url == "/guide/" %}class="active"{% endif %}>guide</a></li>
        <li><a href="/reference/" {% if page.url == "/reference/" %}class="active"{% endif %}>reference</a></li>
        <li><a href="/source/" {% if page.url == "/source/" %}class="active"{% endif %}>source</a></li>
        <li><a href="https://github.com/brennanbrown/writer-cli" class="nav-github">GitHub ↗</a></li>
      </ul>
    </nav>
  </header>

  <main class="main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <p>
      <a href="https://github.com/brennanbrown/writer-cli">writer-cli</a>
      · AGPL-3.0
      · <a href="https://brennan.day">Brennan Kenneth Brown</a>
      · A <a href="https://berryhouse.ca">🍓 Berry House</a> Project
    </p>
  </footer>
</body>
</html>
